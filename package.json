{
  "name": "bmsx-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "",
	"workspaces": [
		"src/bmsx",
		"src/testrom",
		"src/ella2023",
		"src/sint2024"
	],
  "dependencies": {
	"blob": "*",
	"node-fetch": "*",
	"npm": "*",
	"requirejs": "*"
  },
  "devDependencies": {
	"@node-minify/clean-css": "*",
	"@node-minify/core": "*",
	"@node-minify/types": "^9.0.0",
	"@types/bin-pack": "*",
	"@types/blessed": "^0.1.25",
	"@types/cli-progress": "*",
	"@types/js-yaml": "*",
	"@types/node": "^24.3.0",
	"@types/node-fetch": "*",
	"@types/pako": "*",
	"@types/pngjs": "^6.0.5",
	"@types/systemjs": "*",
	"@types/terminal-kit": "*",
	"@types/w3c-web-hid": "^1.0.6",
	"@typescript/native-preview": "^7.0.0-dev.20250604.1",
	"@webgpu/types": "^0.1.64",
	"blessed": "^0.1.81",
	"blessed-contrib": "^4.11.0",
	"canvas": "^3.1.0",
	"colors": "*",
	"dagre": "*",
	"earcut": "^3.0.2",
	"esbuild": "^0.25.3",
	"esbuild-plugin-glsl": "^1.4.0",
	"flatted": "*",
	"ftp-deploy": "*",
	"gauge": "^5.0.1",
	"js-yaml": "*",
	"libkss-js": "*",
	"midi-file": "*",
	"minify-stream": "*",
	"pako": "*",
	"pngjs": "^7.0.0",
	"stringify": "^2.2.0",
	"terminal-kit": "*",
	"tslib": "*",
	"tsx": "^4.20.5",
	"typescript": "^5.8.3",
	"ts-morph": "^22.0.0"
  },
	"scripts": {
		"headless:game": "node scripts/headless-run.js",
		"test:lua": "npx tsx --test tests/lua/*.ts",
		"validate:engine:scripts": "npm run validate:engine && (test -f tsconfig.scripts.json && npm run validate:scripts || true)",
		"validate:engine": "npx tsc --build ./src/bmsx",
		"build:engine:debug": "npx tsx scripts/rompacker/rompacker.ts --mode engine --debug --force --nodeploy --skiptypecheck --platform browser -romname engine -title \"BMSX Engine\" -bootloaderpath ./src/bmsx/console/default_cart -respath ./src/bmsx/res && npx tsx scripts/rompacker/rompacker.ts --mode engine --debug --force --nodeploy --skiptypecheck --platform headless -romname engine -title \"BMSX Engine\" -bootloaderpath ./src/bmsx/console/default_cart -respath ./src/bmsx/res",
	"build:cart": "npx tsx scripts/rompacker/rompacker.ts",
		"build:game": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug -romname ",
	"build:game:force": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --force -romname ",
	"validate:game:force": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --force -romname ",
	"build:game:headless": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --platform headless -romname ",
	"build:game:headless:force": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --platform headless --force -romname ",
	"build:game:cli": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --platform cli -romname ",
	"build:game:cli:force": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --debug --platform cli --force -romname ",
	"build:game:production": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig -romname ",
	"build:game:production:force": "npx tsx scripts/rompacker/rompacker.ts --nodeploy --usepkgtsconfig --force -romname ",
	"pack:engine": "npm pack ./src/bmsx",
	"serve:dist": "node scripts/serve-dist.mjs --dir dist --host 0.0.0.0 --port 8080",
	"serve:dist:wsl": "bash scripts/serve-dist-wsl.sh --port 8080 --dir dist",
	"fix:indent": "node scripts/fix-ts-indentation-safe.js",
	"check:indent": "node scripts/fix-ts-indentation-safe.js --check",
	"build:msxsound": "npx tsgo src/bmsx/msxsound2.ts --removeComments --target ES5",
	"Watch!": "npx tsc -b -w",
	"ast-transform:convert": "node scripts/ast-transform/convert_class_members.js",
	"ast-transform:morph": "node scripts/ast-transform/convert_with_tsmorph.js",
	"ast-transform:morph:project": "node scripts/ast-transform/convert_with_tsmorph.js --project tsconfig.json",
	"test:ast-transform": "node scripts/ast-transform/test/run_test.js",
	"test:ast-transform:project": "node scripts/ast-transform/test/run_project_test.js"
  },

  "repository": {
	"type": "git",
	"url": "git+https://github.com/Heer-Boaz/BMSX.git"
  },
  "author": "Boaz Pat-El",
  "license": "ISC",
  "bugs": {
	"url": "https://github.com/Heer-Boaz/BMSX/issues"
  },
  "homepage": "https://github.com/Heer-Boaz/BMSX#readme"
}
