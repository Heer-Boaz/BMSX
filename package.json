{
  "name": "bmsx",
  "version": "1.0.0",
  "description": "",
  "main": "gulpfile.js",
  "dependencies": {
    "blob": "*",
    "node-fetch": "*",
    "npm": "*",
    "requirejs": "*"
  },
  "devDependencies": {
    "@node-minify/clean-css": "*",
    "@node-minify/core": "*",
    "@node-minify/types": "^9.0.0",
    "@types/bin-pack": "*",
    "@types/cli-progress": "*",
    "@types/js-yaml": "*",
    "@types/node": "*",
    "@types/node-fetch": "*",
    "@types/pako": "*",
    "@types/systemjs": "*",
    "@types/terminal-kit": "*",
    "@typescript/native-preview": "^7.0.0-dev.20250604.1",
    "canvas": "^3.1.0",
    "colors": "*",
    "dagre": "*",
    "esbuild": "^0.25.3",
    "flatted": "*",
    "ftp-deploy": "*",
    "gauge": "^5.0.1",
    "js-yaml": "*",
    "libkss-js": "*",
    "midi-file": "*",
    "minify-stream": "*",
    "pako": "*",
    "stringify": "^2.2.0",
    "terminal-kit": "*",
    "tslib": "*",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build:rom": "npx tsc scripts/rom.ts --removeComments -m commonjs -t ES2017 --outDir rom",
    "build:rompacker": "npx tsc scripts/rompacker.ts --removeComments --target ES5 --outDir rom",
    "pack:resources": "node rom/rompacker.js --buildreslist",
    "build:game": "node rom/rompacker.js -romname $ROMTOBUILD -bootloaderpath src/$ROMTOBUILD -respath ./src/$ROMTOBUILD/res -title $ROMTOBUILD --nodeploy",
    "build:force": "node rom/rompacker.js -romname $ROMTOBUILD -bootloaderpath src/$ROMTOBUILD -respath ./src/$ROMTOBUILD/res -title $ROMTOBUILD --nodeploy --force",
    "build:all": "npm run build:rom && npm run build:rompacker && npm run pack:resources && npm run build:game"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heer-Boaz/BMSX.git"
  },
  "author": "Boaz Pat-El",
