{
	"name": "bmsx-workspace",
	"private": true,
	"version": "1.0.0",
	"description": "",
	"dependencies": {
		"@openai/codex": "^0.115.0",
		"blob": "*",
		"node-fetch": "*",
		"npm": "*",
		"requirejs": "*"
	},
	"devDependencies": {
		"@node-minify/clean-css": "*",
		"@node-minify/core": "*",
		"@node-minify/types": "^9.0.0",
		"@types/bin-pack": "*",
		"@types/cli-progress": "*",
		"@types/js-yaml": "*",
		"@types/node": "^24.3.0",
		"@types/node-fetch": "*",
		"@types/pako": "*",
		"@types/pngjs": "^6.0.5",
		"@types/systemjs": "*",
		"@types/w3c-web-hid": "^1.0.6",
		"@typescript/native-preview": "^7.0.0-dev.20250604.1",
		"@wasm-audio-decoders/ogg-vorbis": "^0.1.20",
		"@webgpu/types": "^0.1.64",
		"canvas": "^3.1.0",
		"cli-progress": "^3.12.0",
		"dagre": "*",
		"earcut": "^3.0.2",
		"esbuild": "^0.25.3",
		"esbuild-plugin-glsl": "^1.4.0",
		"flatted": "*",
		"ftp-deploy": "*",
		"js-yaml": "*",
		"libkss-js": "*",
		"midi-file": "*",
		"minify-stream": "*",
		"pako": "*",
		"picocolors": "^1.0.1",
		"pngjs": "^7.0.0",
		"stringify": "^2.2.0",
		"ts-morph": "^22.0.0",
		"tslib": "*",
		"tsx": "^4.20.5",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"headless:game": "node dist/headless_debug.js --engine-runtime dist/engine.debug.js --engine-assets dist/bmsx-bios.debug.rom",
		"headless:test": "sh -c 'rom=\"$1\"; test=\"$2\"; if [ -z \"$rom\" ] || [ -z \"$test\" ]; then echo \"Usage: npm run headless:test -- <gameromname> <test-file>\"; exit 1; fi; node dist/headless_debug.js --engine-runtime dist/engine.debug.js --engine-assets dist/bmsx-bios.debug.rom --test \"$test\" \"$rom\"' --",
		"headless:forcebuildallrun": "sh -c 'rom=\"$1\"; if [ -z \"$rom\" ]; then echo \"Usage: npm run headless:forcebuildallrun -- <gameromname>\"; exit 1; fi; npm run build:platform:headless -- --debug --force && npm run build:bios -- --debug --force && npx tsx scripts/rompacker/rompacker.ts --mode rompack --skiptypecheck --debug --force -romname \"$rom\" && npm run headless:game -- \"$rom\"' --",
		"headless:forcebuildalltest": "sh -c 'rom=\"$1\"; test=\"$2\"; if [ -z \"$rom\" ] || [ -z \"$test\" ]; then echo \"Usage: npm run headless:forcebuildalltest -- <gameromname> <test-file>\"; exit 1; fi; npm run build:platform:headless -- --debug --force && npm run build:bios -- --debug --force && npx tsx scripts/rompacker/rompacker.ts --mode rompack --skiptypecheck --debug --force -romname \"$rom\" && npm run headless:test -- \"$rom\" \"$test\"' --",
		"test:lua": "npx tsx --test tests/lua/*.ts",
		"test:rompacker": "npx tsx --test tests/rompacker/*.ts",
		"compile:engine": "npx tsc --build ./src/bmsx",
		"validate:bios": "npx tsx scripts/rompacker/rompacker.ts --mode bios --force -bootloaderpath ./src/bmsx/machine/firmware/default_cart -respath ./src/bmsx/res",
		"build:bios": "npx tsx scripts/rompacker/rompacker.ts --mode bios --skiptypecheck -bootloaderpath ./src/bmsx/machine/firmware/default_cart -respath ./src/bmsx/res",
		"validate:game": "npx tsx scripts/rompacker/rompacker.ts --mode rompack --force -romname",
		"build:game": "npx tsx scripts/rompacker/rompacker.ts --mode rompack --skiptypecheck -romname",
		"build:platform:browser": "npx tsx scripts/rompacker/platformbuilder.ts --platform browser",
		"build:platform:headless": "npx tsx scripts/rompacker/platformbuilder.ts --platform headless",
		"build:platform:cli": "npx tsx scripts/rompacker/platformbuilder.ts --platform cli",
		"build:platform:libretro-wsl": "npx tsx scripts/rompacker/platformbuilder.ts --platform libretro-wsl",
		"build:platform:libretro-snesmini": "make SNESMINI_BUILD_TYPE=Release libretro-snesmini-debug",
		"build:platform:libretro-snesmini:debug": "make libretro-snesmini-debug",
		"build:libretro-host-snesmini": "make SNESMINI_BUILD_TYPE=Release libretro-host-snesmini-debug",
		"build:libretro-host-snesmini:debug": "make libretro-host-snesmini-debug",
		"build:libretro-host-wsl:debug": "make libretro-host-wsl-debug",
		"build:platform:libretro-win": "npx tsx scripts/rompacker/platformbuilder.ts --platform libretro-win",
		"deploy:browser": "npx tsx scripts/rompacker/deploybuilder.ts",
		"serve:dist": "node scripts/serve-dist.mjs --dir dist --host 0.0.0.0 --port 8080",
		"serve:dist:wsl": "bash scripts/serve-dist-wsl.sh --port 8080 --dir dist",
		"run:retroarch": "bash run-retroarch.sh",
		"run:libretro-host:wsl:headless": "env SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./build-libretro-host/bmsx_libretro_host --core ./dist/bmsx_libretro.so --video sdl --backend software",
		"run:libretro-host:wsl:sdl": "./build-libretro-host/bmsx_libretro_host --core ./dist/bmsx_libretro.so --video sdl --backend gles2",
		"run:libretro-host:wsl:fb": "./build-libretro-host/bmsx_libretro_host --core ./dist/bmsx_libretro.so --video fb --backend software",
		"clean:dist": "node scripts/clean-dist.mjs",
		"fix:indent": "node scripts/fix-ts-indentation-safe.js",
		"check:indent": "node scripts/fix-ts-indentation-safe.js --check",
		"analyze:code-quality": "npx tsx scripts/analysis/code_quality.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Heer-Boaz/BMSX.git"
	},
	"author": "Boaz Pat-El",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/Heer-Boaz/BMSX/issues"
	},
	"homepage": "https://github.com/Heer-Boaz/BMSX#readme"
}
