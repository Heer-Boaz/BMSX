{
  "name": "bmsx-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "workspaces": [
    "src/bmsx",
    "src/testrom",
    "src/ella2023",
    "src/sint2024"
  ],
  "dependencies": {
    "blob": "*",
    "node-fetch": "*",
    "npm": "*",
    "requirejs": "*"
  },
  "devDependencies": {
    "@node-minify/clean-css": "*",
    "@node-minify/core": "*",
    "@node-minify/types": "^9.0.0",
    "@types/bin-pack": "*",
    "@types/blessed": "^0.1.25",
    "@types/cli-progress": "*",
    "@types/js-yaml": "*",
    "@types/node": "^24.3.0",
    "@types/node-fetch": "*",
    "@types/pako": "*",
    "@types/pngjs": "^6.0.5",
    "@types/systemjs": "*",
    "@types/terminal-kit": "*",
    "@types/w3c-web-hid": "^1.0.6",
    "@typescript/native-preview": "^7.0.0-dev.20250604.1",
    "@webgpu/types": "^0.1.64",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "canvas": "^3.1.0",
    "colors": "*",
    "dagre": "*",
    "esbuild": "^0.25.3",
    "esbuild-plugin-glsl": "^1.4.0",
    "flatted": "*",
    "ftp-deploy": "*",
    "gauge": "^5.0.1",
    "js-yaml": "*",
    "libkss-js": "*",
    "midi-file": "*",
    "minify-stream": "*",
    "pako": "*",
    "pngjs": "^7.0.0",
    "stringify": "^2.2.0",
    "terminal-kit": "*",
    "tslib": "*",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  },
  
  "scripts": {
    "build:game": "npx tsx scripts/rompacker.ts --nodeploy -romname testrom",
    "build:all": "npm run pack:resources && npm run build:force",
    "build:force": "npx tsx scripts/rompacker.ts --nodeploy --force -romname testrom",
    "pack:resources": "npx tsx scripts/rompacker.ts --buildreslist -respath ./src/testrom/res",
    "build:msxsound": "npx tsgo src/bmsx/msxsound2.ts --removeComments --target ES5",
    "Watch!": "npx tsc -b -w",
    "typecheck:scripts": "npx tsc -p tsconfig.scripts.json",
    "pack:engine": "npm pack ./src/bmsx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heer-Boaz/BMSX.git"
  },
