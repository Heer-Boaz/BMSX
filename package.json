{
	"name": "bmsx-workspace",
	"private": true,
	"version": "1.0.0",
	"description": "",
	"workspaces": [
	"src/bmsx",
	"src/testrom",
	"src/ella2023",
	"src/sint2024"
	],
	"dependencies": {
	"blob": "*",
	"node-fetch": "*",
	"npm": "*",
	"requirejs": "*"
	},
	"devDependencies": {
	"@node-minify/clean-css": "*",
	"@node-minify/core": "*",
	"@node-minify/types": "^9.0.0",
	"@types/bin-pack": "*",
	"@types/blessed": "^0.1.25",
	"@types/cli-progress": "*",
	"@types/js-yaml": "*",
	"@types/node": "^24.3.0",
	"@types/node-fetch": "*",
	"@types/pako": "*",
	"@types/pngjs": "^6.0.5",
	"@types/systemjs": "*",
	"@types/w3c-web-hid": "^1.0.6",
	"@typescript/native-preview": "^7.0.0-dev.20250604.1",
	"@webgpu/types": "^0.1.64",
	"blessed": "^0.1.81",
	"blessed-contrib": "^4.11.0",
	"canvas": "^3.1.0",
	"cli-progress": "^3.12.0",
	"dagre": "*",
	"earcut": "^3.0.2",
	"esbuild": "^0.25.3",
	"esbuild-plugin-glsl": "^1.4.0",
	"flatted": "*",
	"ftp-deploy": "*",
	"js-yaml": "*",
	"libkss-js": "*",
	"midi-file": "*",
	"minify-stream": "*",
	"pako": "*",
	"picocolors": "^1.0.1",
	"pngjs": "^7.0.0",
	"stringify": "^2.2.0",
	"ts-morph": "^22.0.0",
	"tslib": "*",
	"tsx": "^4.20.5",
	"typescript": "^5.9.3"
	},
	"scripts": {
	"headless:game": "node scripts/headless-run.js",
	"test:lua": "npx tsx --test tests/lua/*.ts",
	"compile:engine": "npx tsc --build ./src/bmsx",
	"validate:engine": "npx tsx scripts/rompacker/rompacker.ts --mode engine --force -bootloaderpath ./src/bmsx/console/default_cart -respath ./src/bmsx/res",
	"build:engine": "npx tsx scripts/rompacker/rompacker.ts --mode engine --skiptypecheck -bootloaderpath ./src/bmsx/console/default_cart -respath ./src/bmsx/res",
	"validate:game": "npx tsx scripts/rompacker/rompacker.ts --mode rompack --usepkgtsconfig --force -romname",
	"build:game": "npx tsx scripts/rompacker/rompacker.ts --mode rompack --usepkgtsconfig --skiptypecheck -romname",
	"pack:engine": "npm pack ./src/bmsx",
	"build:browser": "npx tsx scripts/rompacker/rompacker.ts --mode platform --platform browser",
	"build:platform:headless": "npx tsx scripts/rompacker/rompacker.ts --mode platform --platform headless",
	"build:platform:cli": "npx tsx scripts/rompacker/rompacker.ts --mode platform --platform cli",
	"build:libretro-wsl": "npx tsx scripts/rompacker/rompacker.ts --mode platform --platform libretro-wsl",
	"build:libretro-snesmini:debug": "make libretro-snesmini-debug",
	"build:libretro-host-snesmini:debug": "make libretro-host-snesmini-debug",
	"build:libretro-host-wsl:debug": "make libretro-host-wsl-debug",
	"build:libretro-win": "npx tsx scripts/rompacker/rompacker.ts --mode platform --platform libretro-win",
	"deploy:browser": "npx tsx scripts/rompacker/rompacker.ts --mode deploy --platform browser --skiptypecheck -romname",
	"serve:dist": "node scripts/serve-dist.mjs --dir dist --host 0.0.0.0 --port 8080",
	"serve:dist:wsl": "bash scripts/serve-dist-wsl.sh --port 8080 --dir dist",
	"run:retroarch": "bash run-retroarch.sh",
	"run:libretro-host:wsl:sdl": "./build-libretro-host/bmsx_libretro_host --core ./dist/bmsx_libretro.so --video sdl --backend software",
	"run:libretro-host:wsl:fb": "./build-libretro-host/bmsx_libretro_host --core ./dist/bmsx_libretro.so --video fb --backend software",
	"fix:indent": "node scripts/fix-ts-indentation-safe.js",
	"check:indent": "node scripts/fix-ts-indentation-safe.js --check"
	},
	"repository": {
	"type": "git",
	"url": "git+https://github.com/Heer-Boaz/BMSX.git"
	},
	"author": "Boaz Pat-El",
	"license": "ISC",
	"bugs": {
	"url": "https://github.com/Heer-Boaz/BMSX/issues"
	},
	"homepage": "https://github.com/Heer-Boaz/BMSX#readme"
}
