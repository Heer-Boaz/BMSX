{
    "extends": "../../tsconfig.json", // Path to the main tsconfig.json file
    "compilerOptions": {
        "composite": true, // Enable project compilation
        "rootDir": "./",
        "tsBuildInfoFile": "./tsconfig.buildinfo",
        "declaration": true,
        "outFile": "./bmsx.js", // Concatenate and emit output to single file. WARNING: This will not work with "module": "system" or "amd" as they require "ES6" target, which does not support features like "private" or "accessors"
        "module": "system", // Won't work with "outFile" and "target": "ESNext", but is required for Codex to compile the code
    },
    "include": [
        ".",
        "rompack/rompack.ts",
        // "../../dist/aynoiseprocessor.js",
    ],
    "exclude": [
        "node_modules",
        "**/bmsx.d.ts",
        "**/bmsx.js",
    ]
}