# Ignore all files under msedge
**/.vscode/edge-profile
**.cs
**/node_modules
**/output
**.dll
**.pdb
**.jpg
**.bmp
**.mp3
**.js.map
# Ignore all minimised CSS files
**.min.css
# Ignore all temporary files
tmp/**
# Ignore all .js files in the rom-folder
rom/**/*.js
!pako_inflate.min.js
!gl-matrix-min.js
# Ignore any temp code runner files
**/tempCodeRunnerFile.*
# Include specific .js files that were previously ignored
**.map
**.tsbuildinfo
**.rom
**.d.ts
!scripts/rompacker/rompacker.rompack.d.ts
!resourceids.d.ts
!rompack.d.ts
rom/ignore
bmsx/**.js
dist/game_debug.html
dist/game.html
dist/manifest.json
!src/bmsx/**.d.ts
src/bmsx/bmsx.d.ts
!src/bmsx/types/globals.d.ts
src/testrom/res/_ignore/detective_piet/**
tsconfig.buildinfo
scripts/tmp
# Ignore all folders named .bmsx (directories only, not files)
**/.bmsx/
# Ignore all files in the `/temp` folder
temp/**

# =============================================================================
# C++ build artifacts
# =============================================================================

# Object files
*.o
*.obj
*.o.d

# Static libraries
*.a
*.lib
*.asm

# Shared libraries
*.so
*.dylib

# Executables (without extension on Linux)
*.exe
*.out

# Temporary files
**.log
**.tmp

# CMake generated files
# CMakeCache.txt
# CMakeFiles/
# cmake_install.cmake
# Makefile
# compile_commands.json
# *.cmake
# !CMakeLists.txt

