{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": false,
		"incremental": false,
		"composite": false,
		"declaration": false,
		"target": "es2024",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"DOM.AsyncIterable",
			"ES2015.Iterable",
			"ES2024"
		],
		"typeRoots": ["node_modules/@types", "node_modules"],
		"types": ["node", "@webgpu/types"],
		"pretty": true,
		// Skip type-checking of declaration files. This helps avoid type errors
		// originating from differing lib declarations (e.g., SharedArrayBuffer vs ArrayBuffer)
		"skipLibCheck": true,
		"preserveConstEnums": false,
		"checkJs": false,
		"assumeChangesOnlyAffectDirectDependencies": false, // Was `true` before, but I think `false` is safer. No reason to have it `false` though
		"noEmitHelpers": true,
		"sourceMap": false,
		"rootDir": ".",
		"removeComments": true,
		"importHelpers": true,
		"downlevelIteration": false,
		"strict": false,
		"noImplicitAny": false,
		"strictNullChecks": false,
		"strictFunctionTypes": false,
		"strictBindCallApply": true,
		"strictPropertyInitialization": false,
		"noImplicitThis": true,
		"alwaysStrict": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": false,
		"useDefineForClassFields": true,
		"noImplicitOverride": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"preserveSymlinks": false,
		"allowUmdGlobalAccess": false,
		"inlineSourceMap": false,
		"inlineSources": false,
		"experimentalDecorators": false,
		"emitDecoratorMetadata": false,
		"allowArbitraryExtensions": true, // For importing `.glsl` files, but I have not tested whether that works
		"allowImportingTsExtensions": true,
		"baseUrl": ".",
		"paths": {
			"bmsx": ["src/bmsx/index.ts"],
			"bmsx/*": ["src/bmsx/*"]
		}
	}
}
