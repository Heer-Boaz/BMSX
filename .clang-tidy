Checks: '-*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  portability-*'
WarningsAsErrors: ''
HeaderFilterRegex: 'src/bmsx_cpp/.*'
FormatStyle: file

CheckOptions:
  - key: modernize-loop-convert.MakeStaticOperator::value
    value: 0
  - key: readability-function-size.LineThreshold
    value: 400
  - key: readability-function-size.ParameterThreshold
    value: 16
  - key: readability-function-size.StatementThreshold
    value: 200
