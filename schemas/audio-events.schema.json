{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://bmsx.dev/schemas/audio-events.schema.json",
	"title": "BMSX Audio Event Map",
	"description": "Schema describing audio event maps consumed by the BMSX engine.",
	"type": "object",
	"properties": {
		"events": {
			"type": "object",
			"additionalProperties": {
				"$ref": "#/definitions/audioEventEntry"
			}
		}
	},
	"additionalProperties": {
		"$ref": "#/definitions/audioEventEntry"
	},
	"definitions": {
		"asset_id": {
			"description": "Asset identifier (string).",
			"type": "string"
		},
		"audioEventEntry": {
			"type": "object",
			"description": "Top-level audio event entry.",
			"properties": {
				"name": {
					"type": "string"
				},
				"channel": {
					"type": "string",
					"enum": [
						"sfx",
						"music",
						"ui"
					]
				},
				"policy": {
					"type": "string",
					"enum": [
						"replace",
						"ignore",
						"queue",
						"stop",
						"pause"
					]
				},
				"max_voices": {
					"type": "integer",
					"minimum": 1
				},
				"rules": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/audioEventRule"
					}
				}
			},
			"required": [
				"rules"
			],
			"additionalProperties": false,
			"allOf": [
				{
					"if": {
						"properties": {
							"rules": {
								"type": "array",
								"contains": {
									"type": "object",
									"required": [
										"go"
									],
									"properties": {
										"go": {
											"type": "object",
											"required": [
												"music_transition"
											],
											"properties": {
												"music_transition": {
													"type": "object"
												}
											}
										}
									}
								}
							}
						}
					},
					"then": {
						"properties": {
							"channel": {
								"const": "music"
							}
						},
						"required": [
							"channel"
						]
					}
				}
			]
		},
		"audioEventRule": {
			"type": "object",
			"properties": {
				"when": {
					"$ref": "#/definitions/audioCaseMatcher"
				},
				"go": {
					"$ref": "#/definitions/audioActionSpec"
				}
			},
			"required": [
				"go"
			],
			"additionalProperties": false
		},
		"audioCaseMatcher": {
			"type": "object",
			"properties": {
				"equals": {
					"type": "object",
					"additionalProperties": true
				},
				"any_of": {
					"type": "object",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"in": {
					"type": "object",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"has_tag": {
					"$ref": "#/definitions/stringArray"
				},
				"and": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/audioCaseMatcher"
					}
				},
				"or": {
					"type": "array",
					"items": {
						"$ref": "#/definitions/audioCaseMatcher"
					}
				},
				"not": {
					"$ref": "#/definitions/audioCaseMatcher"
				}
			},
			"additionalProperties": true
		},
		"audioActionSpec": {
			"one_of": [
				{
					"$ref": "#/definitions/audioAction"
				},
				{
					"$ref": "#/definitions/audioActionOneOfSpec"
				},
				{
					"$ref": "#/definitions/musicTransitionSpec"
				}
			]
		},
		"audioAction": {
			"type": "object",
			"properties": {
				"audio_id": {
					"$ref": "#/definitions/asset_id"
				},
				"modulation_preset": {
					"type": "string"
				},
				"priority": {
					"type": "number",
					"minimum": 0
				},
				"cooldown_ms": {
					"type": "number",
					"minimum": 0
				}
			},
			"required": [
				"audio_id"
			],
			"additionalProperties": false
		},
		"audioActionOneOfSpec": {
			"type": "object",
			"properties": {
				"one_of": {
					"type": "array",
					"items": {
						"any_of": [
							{
								"$ref": "#/definitions/asset_id"
							},
							{
								"type": "object",
								"properties": {
									"audio_id": {
										"$ref": "#/definitions/asset_id"
									},
									"modulation_preset": {
										"type": "string"
									},
									"priority": {
										"type": "number",
										"minimum": 0
									},
									"cooldown_ms": {
										"type": "number",
										"minimum": 0
									},
									"weight": {
										"type": "number",
										"minimum": 0
									}
								},
								"required": [
									"audio_id"
								],
								"additionalProperties": false
							}
						]
					}
				},
				"pick": {
					"type": "string",
					"enum": [
						"uniform",
						"weighted"
					]
				},
				"avoid_repeat": {
					"type": "boolean"
				}
			},
			"required": [
				"one_of"
			],
			"additionalProperties": false
		},
		"musicTransitionSpec": {
			"type": "object",
			"properties": {
				"music_transition": {
					"type": "object",
					"properties": {
						"audio_id": {
							"$ref": "#/definitions/asset_id"
						},
						"sync": {
							"$ref": "#/definitions/musicTransitionSync"
						},
						"fade_ms": {
							"type": "number",
							"minimum": 0
						},
						"start_at_loop_start": {
							"type": "boolean"
						},
						"start_fresh": {
							"type": "boolean"
						}
					},
					"additionalProperties": false,
					"any_of": [
						{
							"required": [
								"audio_id"
							]
						},
						{
							"required": [
								"sync"
							],
							"properties": {
								"sync": {
									"$ref": "#/definitions/stingerSync"
								}
							}
						}
					]
				}
			},
			"required": [
				"music_transition"
			],
			"additionalProperties": false
		},
		"musicTransitionSync": {
			"one_of": [
				{
					"type": "string",
					"enum": [
						"immediate",
						"loop"
					]
				},
				{
					"type": "object",
					"properties": {
						"delay_ms": {
							"type": "number",
							"minimum": 0
						}
					},
					"required": [
						"delay_ms"
					],
					"additionalProperties": false
				},
				{
					"$ref": "#/definitions/stingerSync"
				}
			]
		},
		"stingerSync": {
			"type": "object",
			"properties": {
				"stinger": {
					"$ref": "#/definitions/asset_id"
				},
				"return_to": {
					"$ref": "#/definitions/asset_id"
				},
				"return_to_previous": {
					"type": "boolean"
				}
			},
			"required": [
				"stinger"
			],
			"additionalProperties": false,
			"allOf": [
				{
					"not": {
						"required": [
							"return_to",
							"return_to_previous"
						]
					}
				}
			]
		},
		"stringArray": {
			"type": "array",
			"items": {
				"type": "string"
			}
		}
	}
}
