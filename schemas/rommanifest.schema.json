{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://bmsx.dev/schemas/cart-manifest.schema.json",
	"title": "BMSX Cart Manifest",
	"description": "Schema describing cartridge manifest files (manifest.rommanifest) consumed by the BMSX engine.",
	"type": "object",
	"properties": {
		"title": {
			"type": "string",
			"description": "Human-readable title of the cartridge."
		},
		"short_name": {
			"type": "string",
			"description": "Short display name of the cartridge."
		},
		"rom_name": {
			"type": "string",
			"description": "ROM filename base (without extension)."
		},
		"machine": {
			"$ref": "#/definitions/machineConfig"
		},
		"input": {
			"$ref": "#/definitions/inputConfig"
		},
		"lua": {
			"$ref": "#/definitions/luaConfig"
		}
	},
	"required": [
		"lua"
	],
	"additionalProperties": false,
	"definitions": {
		"viewport": {
			"type": "object",
			"description": "Logical viewport size for the cartridge.",
			"properties": {
				"width": {
					"type": "integer",
					"minimum": 1
				},
				"height": {
					"type": "integer",
					"minimum": 1
				}
			},
			"required": [
				"width",
				"height"
			],
			"additionalProperties": false
		},
		"canonicalization": {
			"type": "string",
			"enum": [
				"none",
				"upper",
				"lower"
			],
			"description": "Canonicalization mode for Lua identifiers."
		},
		"machineConfig": {
			"type": "object",
			"description": "Machine configuration for the cartridge.",
			"properties": {
				"viewport": {
					"$ref": "#/definitions/viewport"
				},
				"canonicalization": {
					"$ref": "#/definitions/canonicalization"
				},
				"namespace": {
					"type": "string",
					"description": "Namespace used for this cart (e.g. for Lua globals)."
				},
				"ufps": {
					"type": "integer",
					"minimum": 1,
					"description": "Machine tick rate in scaled Hz (micro-Hz). Example: 59.94 Hz => 59940000."
				},
				"specs": {
					"$ref": "#/definitions/machineSpecs"
				}
			},
			"required": [
				"namespace",
				"ufps",
				"specs"
			],
			"additionalProperties": false
		},
		"machineSpecs": {
			"type": "object",
			"description": "Machine specs for performance limits and memory budgets.",
			"properties": {
				"cpu": {
					"$ref": "#/definitions/machineCpuSpecs"
				},
				"dma": {
					"$ref": "#/definitions/machineDmaSpecs"
				},
				"audio": {
					"$ref": "#/definitions/machineAudioSpecs"
				},
				"ram": {
					"$ref": "#/definitions/machineRamSpecs"
				},
				"vdp": {
					"$ref": "#/definitions/machineVdpSpecs"
				},
				"vram": {
					"$ref": "#/definitions/machineVramSpecs"
				}
			},
			"required": [
				"cpu",
				"dma",
				"vdp"
			],
			"additionalProperties": false
		},
		"machineVdpSpecs": {
			"type": "object",
			"description": "Video timing specs.",
			"properties": {
				"vblank_cycles": {
					"type": "integer",
					"minimum": 1,
					"description": "Number of cycles in the VBLANK window at the end of each frame."
				}
			},
			"required": [
				"vblank_cycles"
			],
			"additionalProperties": false
		},
		"machineCpuSpecs": {
			"type": "object",
			"description": "CPU throughput specs.",
			"properties": {
				"cpu_freq_hz": {
					"type": "integer",
					"minimum": 1,
					"description": "CPU cycle rate in Hz."
				},
				"imgdec_bytes_per_sec": {
					"type": "integer",
					"minimum": 1,
					"description": "IMGDEC output (decoded RGBA) throughput in bytes per second."
				}
			},
			"required": [
				"cpu_freq_hz",
				"imgdec_bytes_per_sec"
			],
			"additionalProperties": false
		},
		"machineDmaSpecs": {
			"type": "object",
			"description": "DMA throughput specs.",
			"properties": {
				"dma_bytes_per_sec_iso": {
					"type": "integer",
					"minimum": 1,
					"description": "DMA isochronous channel bandwidth in bytes per second."
				},
				"dma_bytes_per_sec_bulk": {
					"type": "integer",
					"minimum": 1,
					"description": "DMA bulk channel bandwidth in bytes per second."
				}
			},
			"required": [
				"dma_bytes_per_sec_iso",
				"dma_bytes_per_sec_bulk"
			],
			"additionalProperties": false
		},
		"machineRamSpecs": {
			"type": "object",
			"description": "RAM and asset memory budgets.",
			"properties": {
				"ram_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"string_handle_count": {
					"type": "integer",
					"minimum": 1
				},
				"string_heap_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"asset_table_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"asset_data_bytes": {
					"type": "integer",
					"minimum": 1
				}
			},
			"additionalProperties": false
		},
		"machineVramSpecs": {
			"type": "object",
			"description": "VRAM and rendering budgets.",
			"properties": {
				"atlas_slot_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"engine_atlas_slot_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"staging_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"skybox_face_size": {
					"type": "integer",
					"minimum": 1,
					"description": "Maximum skybox face size in pixels (square)."
				},
				"skybox_face_bytes": {
					"type": "integer",
					"minimum": 1,
					"description": "Skybox face capacity in bytes (overrides skybox_face_size when set)."
				}
			},
			"additionalProperties": false
		},
		"machineAudioSpecs": {
			"type": "object",
			"description": "Audio budgets.",
			"properties": {
				"max_voices": {
					"$ref": "#/definitions/machineVoiceSpecs"
				}
			},
			"additionalProperties": false
		},
		"machineVoiceSpecs": {
			"type": "object",
			"description": "Per-channel voice caps.",
			"properties": {
				"sfx": {
					"type": "integer",
					"minimum": 1
				},
				"music": {
					"type": "integer",
					"minimum": 1
				},
				"ui": {
					"type": "integer",
					"minimum": 1
				}
			},
			"additionalProperties": false
		},
		"inputMap": {
			"type": "object",
			"description": "Input mapping configuration for a single player slot.",
			"properties": {
				"keyboard": {
					"type": "object",
					"description": "Keyboard mapping for console controls.",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"gamepad": {
					"type": "object",
					"description": "Gamepad mapping for console controls.",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"pointer": {
					"type": "object",
					"description": "Pointer / mouse / touch mapping for console controls.",
					"additionalProperties": true
				}
			},
			"additionalProperties": true
		},
		"inputConfig": {
			"type": "object",
			"description": "Per-player input configuration.",
			"properties": {
				"1": {
					"$ref": "#/definitions/inputMap"
				},
				"2": {
					"$ref": "#/definitions/inputMap"
				},
				"3": {
					"$ref": "#/definitions/inputMap"
				},
				"4": {
					"$ref": "#/definitions/inputMap"
				}
			},
			"required": [
				"1"
			],
			"additionalProperties": false
		},
		"luaConfig": {
			"type": "object",
			"description": "Lua entrypoint configuration for the cartridge.",
			"properties": {
				"entry_path": {
					"type": "string",
					"description": "Path to the Lua source that acts as the main entry for the cart."
				}
			},
			"required": [
				"entry_path"
			],
			"additionalProperties": false
		},
		"stringArray": {
			"type": "array",
			"items": {
				"type": "string"
			}
		}
	}
}
