{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://bmsx.dev/schemas/cart-manifest.schema.json",
	"title": "BMSX Cart Manifest",
	"description": "Schema describing cartridge manifest files (manifest.rommanifest) consumed by the BMSX engine.",
	"type": "object",
	"properties": {
		"title": {
			"type": "string",
			"description": "Human-readable title of the cartridge."
		},
		"short_name": {
			"type": "string",
			"description": "Short display name of the cartridge."
		},
		"rom_name": {
			"type": "string",
			"description": "ROM filename base (without extension)."
		},
		"vm": {
			"$ref": "#/definitions/vmConfig"
		},
		"input": {
			"$ref": "#/definitions/inputConfig"
		},
		"lua": {
			"$ref": "#/definitions/luaConfig"
		}
	},
	"required": [
		"lua"
	],
	"additionalProperties": false,
	"definitions": {
		"viewport": {
			"type": "object",
			"description": "Logical viewport size for the cartridge.",
			"properties": {
				"width": {
					"type": "integer",
					"minimum": 1
				},
				"height": {
					"type": "integer",
					"minimum": 1
				}
			},
			"required": [
				"width",
				"height"
			],
			"additionalProperties": false
		},
		"canonicalization": {
			"type": "string",
			"enum": [
				"none",
				"upper",
				"lower"
			],
			"description": "Canonicalization mode for Lua identifiers."
		},
		"vmConfig": {
			"type": "object",
			"description": "VM configuration for the cartridge.",
			"properties": {
				"viewport": {
					"$ref": "#/definitions/viewport"
				},
				"canonicalization": {
					"$ref": "#/definitions/canonicalization"
				},
				"namespace": {
					"type": "string",
					"description": "Namespace used for this cart (e.g. for Lua globals)."
				},
				"skybox_face_size": {
					"type": "integer",
					"minimum": 1,
					"description": "Maximum skybox face size in pixels (square)."
				},
				"cpu_freq_hz": {
					"type": "integer",
					"minimum": 1,
					"description": "VM cycle rate in Hz."
				},
				"imgdec_bytes_per_sec": {
					"type": "integer",
					"minimum": 1,
					"description": "IMGDEC output (decoded RGBA) throughput in bytes per second."
				},
				"dma_bytes_per_sec_iso": {
					"type": "integer",
					"minimum": 1,
					"description": "DMA isochronous channel bandwidth in bytes per second."
				},
				"dma_bytes_per_sec_bulk": {
					"type": "integer",
					"minimum": 1,
					"description": "DMA bulk channel bandwidth in bytes per second."
				},
					"ufps": {
						"type": "integer",
						"minimum": 1,
						"description": "VM tick rate in scaled Hz (micro-Hz). Example: 59.94 Hz => 59940000."
					},
				"limits": {
					"$ref": "#/definitions/vmLimits"
				}
			},
			"required": [
				"namespace",
				"cpu_freq_hz",
				"imgdec_bytes_per_sec",
				"dma_bytes_per_sec_iso",
				"dma_bytes_per_sec_bulk",
				"ufps"
			],
			"additionalProperties": false
		},
			"vmLimits": {
				"type": "object",
				"description": "Soft VM limits for memory and runtime budgets.",
				"properties": {
					"ram_bytes": {
						"type": "integer",
						"minimum": 1
					},
					"string_handle_count": {
						"type": "integer",
						"minimum": 1
					},
					"string_heap_bytes": {
						"type": "integer",
						"minimum": 1
					},
					"asset_table_bytes": {
						"type": "integer",
						"minimum": 1
					},
					"asset_data_bytes": {
						"type": "integer",
						"minimum": 1
					},
					"atlas_slot_bytes": {
						"type": "integer",
						"minimum": 1
					},
				"staging_bytes": {
					"type": "integer",
					"minimum": 1
				},
				"max_voices": {
					"$ref": "#/definitions/vmVoiceLimits"
				}
			},
			"additionalProperties": false
		},
		"vmVoiceLimits": {
			"type": "object",
			"description": "Per-channel voice caps.",
			"properties": {
				"sfx": {
					"type": "integer",
					"minimum": 1
				},
				"music": {
					"type": "integer",
					"minimum": 1
				},
				"ui": {
					"type": "integer",
					"minimum": 1
				}
			},
			"additionalProperties": false
		},
		"inputMap": {
			"type": "object",
			"description": "Input mapping configuration for a single player slot.",
			"properties": {
				"keyboard": {
					"type": "object",
					"description": "Keyboard mapping for vm controls.",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"gamepad": {
					"type": "object",
					"description": "Gamepad mapping for vm controls.",
					"additionalProperties": {
						"$ref": "#/definitions/stringArray"
					}
				},
				"pointer": {
					"type": "object",
					"description": "Pointer / mouse / touch mapping for vm controls.",
					"additionalProperties": true
				}
			},
			"additionalProperties": true
		},
		"inputConfig": {
			"type": "object",
			"description": "Per-player input configuration.",
			"properties": {
				"1": {
					"$ref": "#/definitions/inputMap"
				},
				"2": {
					"$ref": "#/definitions/inputMap"
				},
				"3": {
					"$ref": "#/definitions/inputMap"
				},
				"4": {
					"$ref": "#/definitions/inputMap"
				}
			},
			"required": [
				"1"
			],
			"additionalProperties": false
		},
		"luaConfig": {
			"type": "object",
			"description": "Lua entrypoint configuration for the cartridge.",
			"properties": {
				"entry_path": {
					"type": "string",
					"description": "Path to the Lua source that acts as the main entry for the cart."
				}
			},
			"required": [
				"entry_path"
			],
			"additionalProperties": false
		},
		"stringArray": {
			"type": "array",
			"items": {
				"type": "string"
			}
		}
	}
}
