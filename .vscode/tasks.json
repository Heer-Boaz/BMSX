	"inputs": [
		{
			"type": "pickString",
			"id": "romtobuild",
			"description": "Choose ROM to build",
			"options": [
				"marlies2020console",
				"luashell",
				"luademo",
				"bmsxconsole",
				"sint2024",
				"ella2023",
				"testrom",
				"joanneke2022",
