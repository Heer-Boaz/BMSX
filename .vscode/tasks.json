{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build & pack",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"build rom",
				"build rompacker",
				"build game",
				// "minify"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem"
			}
		},
		{
			"label": "pack (losse taak)",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "none",
			"dependsOn": [
				"build rompacker",
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem"
			}
		},
		{
			"label": "minify",
			"type": "shell",
			"command": "terser",
			"args": [
				"--compress",
				"--mangle",
				"--source-map",
				"filename=\"thegame.js\"",
				"--source-map",
				"root='${workspaceFolder}\\src\\'",
				"--source-map",
				"content=\"inline\"",
				"--source-map",
				"url=\"inline\"",
				"--output",
				"${workspaceFolder}\\rom\\thegame.js",
				"${workspaceFolder}\\rom\\thegame.js"
			],
			"problemMatcher": [
				"$node-sass"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem"
			},
			"group": "build",
			"dependsOn": [
				"build game"
			]
		},
		{
			"label": "build game",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem"
			},
			"group": "build"
		},
		{
			"label": "build rom",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rom.ts",
				"--removeComments",
				"-m",
				"\"none\"",
				"-t",
				"ES2019",
				"--outDir",
				"\"${workspaceFolder}\\rom\""
			],
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build"
		},
		{
			"label": "build rompacker",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rompacker.ts",
				"--removeComments",
				"--noEmitHelpers",
				"--outDir",
				"\"${workspaceFolder}\\rom\""
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			}
		},
		{
			"type": "gulp",
			"task": "my-task",
			"problemMatcher": []
		}
	]
}