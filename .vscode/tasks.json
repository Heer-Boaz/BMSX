{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
		},
		{
			"label": "build watch",
			"type": "shell",
			"command": "tsc",
			"args": [
				"--build",
				"${workspaceFolder}\\tsconfig.json",
				"--watch"
			],
			// "runOptions": { "runOn": "folderOpen" },
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$tsc-watch"
			]
		}
	]
}