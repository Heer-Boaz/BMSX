{
	"version": "2.0.0",
	// "_runner": "terminal",
	"tasks": [
		{
			"label": "build the game DEBUG-MODE",
			"detail": "Runs rompacker.js to create the DEBUG ROM + resources. Doesn't run dependent tasks for building rom.js & rompacker.js!",
			"type": "shell",
			"command": "npx",
			"args": [
				"tsx",
				"${workspaceFolder}/scripts/rompacker/rompacker.ts",
				"-romname",
				"${input:romtobuild}",
				"-bootloaderpath",
				"src/${input:romtobuild}",
				"-respath",
				"./src/${input:romtobuild}/res",
				"-title",
				"${input:romtobuild}",
				"--debug",
				"--nodeploy",
				"--skiptypecheck",
				"--usepkgtsconfig"
			],
			"problemMatcher": [
				"$node-sass",
				"$tsc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOrder": "sequence",
			"dependsOn": [
				"output romtobuild"
			],
			"icon": {
				"id": "game",
				"color": "terminal.ansiGreen"
			},
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "ROMPACKER"
			}
		},
