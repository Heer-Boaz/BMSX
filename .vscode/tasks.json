{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"dependsOn": [
				"pack"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
		},
		{
			"label": "pack",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "build",
			"dependsOrder": "parallel",
			"dependsOn": [
				"build rom",
				"build rompacker",
				"build game",
				// "minify",
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "boaz",
			}
		},
		{
			"label": "pack (losse taak)",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "none",
			"dependsOn": [
				"build rompacker",
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "pack rom without build",
			}
		},
