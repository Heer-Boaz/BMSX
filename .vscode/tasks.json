	"version": "2.0.0",
	"tasks": [
		{
			"label": "build & pack",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"build rom",
				"build rompacker",
				"build game",
				// "minify",
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
		},
