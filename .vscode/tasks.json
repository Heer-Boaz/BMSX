		{
			"label": "build game",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build",
		},
		{
			"label": "build rom",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rom.ts",
				"--removeComments",
				// "--noEmitHelpers",
				"-m",
				"\"none\"",
				"-t",
				"ES2019",
				"--outDir",
				"\"${workspaceFolder}\\rom\"",
			],
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
			"group": "build"
		},
		{
			"label": "build rompacker",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rompacker.ts",
				"--removeComments",
				"--noEmitHelpers",
				"--outDir",
				"\"${workspaceFolder}\\rom\"",
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			},
		},
