{
	"version": "2.0.0",
	"_runner": "terminal",
	"tasks": [
		{
			"label": "build the game",
			"dependsOn": [
				"pack"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "pack",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}/rom/rompacker.js",
				"-outfile",
				"${input:romtobuild}.rom",
				"-bootloaderpath",
				"src/${input:romtobuild}/bootloader.ts",
				"-respath",
				"./src/${input:romtobuild}/res",
				"-title",
				"${input:romtobuild}",
				"--force"
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "build",
			"dependsOrder": "parallel",
			"dependsOn": [
				"output romtobuild",
				"build rom",
				"build resourceids.ts"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "ROMPACKER"
			}
		},
		// {
		// 	"label": "build game",
		// 	"type": "typescript",
		// 	"tsconfig": "tsconfig.json",
		// 	"problemMatcher": [
		// 		"$tsc"
		// 	],
		// 	"presentation": {
		// 		"echo": true,
		// 		"reveal": "always",
		// 		"focus": false,
		// 		"panel": "dedicated",
		// 		"showReuseMessage": true,
		// 		"clear": true,
		// 		"revealProblems": "onProblem",
		// 		"group": "boaz"
		// 	},
		// 	"group": "build"
		// },
		{
			"label": "build rom",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}/scripts/rom.ts",
				"--removeComments",
				"-m",
				"commonjs",
				"-t",
				"ES5",
				"--outDir",
				"${workspaceFolder}/rom"
			],
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "TSC"
			},
			"group": "build"
		},
		{
			"label": "build resourceids.ts",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}/rom/rompacker.js",
				"-respath",
				"./src/${input:romtobuild}/res",
				"--buildreslist"
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "build",
			"dependsOrder": "parallel",
			"dependsOn": [
				"build rompacker"
			],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "ROMPACKER"
			}
		},
		{
			"label": "build rompacker",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}/scripts/rompacker.ts",
				"--removeComments",
				"--target",
				"ES5",
				"--outDir",
				"${workspaceFolder}/rom"
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "TSC"
			}
		},
		{
			"label": "output romtobuild",
			"type": "shell",
			"command": "echo",
			"args": [
				"${input:romtobuild}",
			],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "TSC"
			}
		},
	],
	"inputs": [
		{
			"type": "pickString",
			"id": "romtobuild",
			"description": "Choose ROM to build",
			"options": [
				"Marlies2020",
				"Sintervania",
				"Testrom",
			],
			"default": "Marlies2020"
		}
	]
}