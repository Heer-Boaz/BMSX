{
	"version": "2.0.0",
	"_runner": "terminal",
	"tasks": [
		{
			"label": "build debug",
			"dependsOn": [
				"pack"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
		},
		{
			"label": "pack",
			"type": "process",
			"command": "node",
			"args": [
				"${workspaceFolder}/rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$func-watch"
			],
			"group": "build",
			"dependsOrder": "parallel",
			"dependsOn": [
				"build rom",
				"build rompacker",
				// "build game",
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "ROMPACKER",
			}
		},
		{
			"label": "pack (losse taak)",
			"type": "shell",
			"command": "node",
			"args": [
				"${workspaceFolder}\\rom\\rompacker.js",
				"sintervania.rom",
			],
			"problemMatcher": [
				"$node-sass"
			],
			"group": "none",
			"dependsOn": [
				"build rompacker",
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "pack rom without build",
			}
		},
		{
			"label": "build game",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "boaz",
			},
			"group": "build",
		},
		{
			"label": "build rom",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}/scripts/rom.ts",
				"--removeComments",
				"-m",
				"commonjs",
				"-t",
				"ES5",
				"--outDir",
				"${workspaceFolder}/rom"
			],
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "TSC",
			},
			"group": "build"
		},
		{
			"label": "build rompacker",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}/scripts/rompacker.ts",
				"--removeComments",
				// "--noEmitHelpers",
				"--outDir",
				"${workspaceFolder}/"
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "TSC",
			}
		},
		{
			"type": "gulp",
			"task": "my-task",
			"problemMatcher": []
		}
	]
}