			],
			"hide": true,
			"group": "build",
			"icon": {
				"id": "output",
				"color": "terminal.ansiBlack"
			},
			"presentation": {
				"echo": false,
				"reveal": "never",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"close": true,
				"clear": true,
				"group": "ROMPACKER"
			},
			"problemMatcher": []
		},
		{
			"type": "npm",
			"script": "fix:indent",
			"problemMatcher": [],
			"label": "npm: fix:indent",
			"detail": "node scripts/fix-ts-indentation-safe.js"
		},
		{
			"type": "npm",
			"script": "build:game",
			"group": "build",
			"problemMatcher": [],
			"label": "npm: build:game",
			"detail": "npx tsx scripts/rompacker/rompacker.ts --nodeploy -romname testrom",
		}
