		// },
		{
			"label": "build game",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"revealProblems": "onProblem",
				"group": "boaz",
			},
			"group": "build",
		},
		{
			"label": "build rom",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rom.ts",
				"--removeComments",
				"-m",
				"\"commonjs\"",
				"-t",
				"ES5",
				// "--types",
				// "${workspaceFolder}\\BoazEngineJS\\rompack",
				"--outDir",
				"\"${workspaceFolder}\\rom\""
			],
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "boaz",
			},
			"group": "build"
		},
		{
			"label": "build rompacker",
			"type": "shell",
			"command": "tsc",
			"args": [
				"${workspaceFolder}\\BoazEngineJS\\rompacker.ts",
				"--removeComments",
				"--noEmitHelpers",
				// "--types",
				// "${workspaceFolder}\\BoazEngineJS\\rompack",
				"--outDir",
				"\"${workspaceFolder}\\rom\""
			],
			"problemMatcher": [
				"$tsc"
			],
			"group": "build",
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"group": "boaz",
			}
		},
		{
			"type": "gulp",
			"task": "my-task",
			"problemMatcher": []
		}
	]
}