{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the game!",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222",
				// "--app=file://${workspaceFolder}/dist/game_debug.html"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				// "file:///B:/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				// "../scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Run the game in non-debug mode!",
			"url": "${workspaceFolder}/dist/game.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate"
				,
				"--remote-debugging-port=9222"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 2
			}
		},
		{
			"type": "msedge",
			"name": "Open Edge DevTools",
			"request": "attach",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"port": 9222,
			"presentation": {
				"hidden": true
			}
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the game! (WSL)",
			"url": "file:////wsl$/Ubuntu/home/boaz/BMSX/dist/game_debug.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile-wsl",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222",
				"--app=file:////wsl$/Ubuntu/home/boaz/BMSX/dist/game_debug.html"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"file:///home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the game from WSL Server!",
			"url": "http://localhost:8080/game_debug.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile-wsl",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222",
				"--app=http://localhost:8080/game_debug.html"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"file:///home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": false,
			"smartStep": true,
			"disableNetworkCache": true,
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Release the game from WSL Server!",
			"url": "http://localhost:8080/game.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile-wsl",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222",
				"--app=http://localhost:8080/game.html"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"file:///home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": false,
			"smartStep": true,
			"disableNetworkCache": true,
		}
		{
			"type": "pwa-node",
			"request": "launch",
			"name": "LIBRETRO RUN: RetroArch",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"run:retroarch",
				"--",
				"./dist/${input:romtobuild}.rom"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal"
		},
		{
			"type": "pwa-node",
			"request": "launch",
			"name": "LIBRETRO RUN: Custom Host",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"run:libretro-host:wsl",
				"--",
				"./dist/${input:romtobuild}.rom"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal"
		}
		,
		{
			"type": "pwa-node",
			"request": "launch",
			"name": "GAME RUN: headless",
			"runtimeExecutable": "npm",
			"runtimeArgs": [
				"run",
				"headless:game",
				"--",
				"${input:romtobuild}"
			],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal"
		}
	],
	"inputs": [
		{
			"type": "pickString",
			"id": "romtobuild",
			"description": "Choose ROM to build",
			"options": [
				"2025",
				"emptycart",
				"sint2024",
				"ella2023",
				"testrom",
				"joanneke2022",
				"marlies2021",
				"marlies2020",
				"sintervania"
			],
			"default": "2025"
		}
	],
}
