{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the game!",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				// "file:///B:/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				// "../scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the MSXSOUND!",
			"url": "${workspaceFolder}/src/bmsx/bla.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate",
				"--remote-debugging-port=9222"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 3
			}
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Run the game in non-debug mode!",
			"url": "${workspaceFolder}/dist/game.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate"
				,
				"--remote-debugging-port=9222"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 2
			}
		},
		{
			"type": "msedge",
			"name": "Open Edge DevTools",
			"request": "attach",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"port": 9222,
			"presentation": {
				"hidden": true
			}
		},
		{
			"type": "msedge",
			"name": "a:/src/ASCII-art.html",
			"request": "launch",
			"url": "a:/src/ASCII-art.html",
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate",
				"--remote-debugging-port=9222"
			]
		},
		{
			"type": "msedge",
			"name": "http://127.0.0.1:3000/scripts/ascii_shader.html",
			"request": "launch",
			"url": "http://127.0.0.1:3000/scripts/ascii_shader.html",
			"runtimeArgs": [
				"--remote-debugging-port=9222"
			]
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Debug the game! (WSL)",
			"url": "file:////wsl$/Ubuntu/home/boaz/BMSX/dist/game_debug.html",
			"userDataDir": "${workspaceFolder}/.vscode/edge-profile-wsl",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"--disable-features=IsolateOrigins,site-per-process,web-security",
				"--remote-debugging-port=9222"
			],
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true,
			"sourceMapPathOverrides": {
				"file:///home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"/home/boaz/BMSX/scripts/*": "${workspaceFolder}/scripts/*",
				"*": "${workspaceFolder}/src/*"
			},
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true
		}
	],
	// "compounds": [
	// 	{
	// 		"name": "Launch Edge and attach DevTools",
	// 		"configurations": [
	// 			"Debug the game!",
	// 			"Open Edge DevTools"
	// 		]
	// 	}
	// ],
}
