{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "msedge",
			"version": "stable",
			"request": "launch",
			"name": "Debug the game!",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"runtimeArgs": [
				// "--disable-web-security", // Old and outdated, but it works when using the non-debug URL!
				// "--headless",
				"--nolazy",
				"--allow-file-access-from-files", // https://www.webmo.net/link/help/AccessingLocalFiles.html
				"--disable-session-crashed-bubble",
				"-inprivate", // https://dev.to/kasuken/debug-with-visual-studio-using-all-browsers-in-incognito-mode-57mb
				"--remote-debugging-port=9222",
				// "--start-fullscreen",
				// "--kiosk",
				// "--edge-kiosk-type=public-browsing",
			],
			"sourceMaps": true,
			// "sourceMapPathOverrides": {
			// 	"meteor://💻app/*": "${workspaceFolder}/*",
			// 	"webpack:///./~/*": "${workspaceFolder}/node_modules/*",
			// 	"webpack://?:*/*": "${workspaceFolder}/*",
			// 	"webpack:///./*": "${webRoot}/*",
			// 	"webpack:///src/*": "${webRoot}/*",
			// 	"webpack:///*": "*"
			// },
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 1,
			}
		},
		{
			"type": "msedge",
			"version": "stable",
			"request": "launch",
			"name": "Run the game in non-debug mode!",
			"url": "${workspaceFolder}/dist/game.html",
			"runtimeArgs": [
				// "--disable-web-security", // Old and outdated, but it works when using the non-debug URL!
				"--nolazy",
				"--allow-file-access-from-files", // https://www.webmo.net/link/help/AccessingLocalFiles.html
				"--disable-session-crashed-bubble",
				"-inprivate", // https://dev.to/kasuken/debug-with-visual-studio-using-all-browsers-in-incognito-mode-57mb
				// "--start-fullscreen",
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 2
			}
		},
		{
			"type": "vscode-edge-devtools.debug",
			"name": "Open Edge DevTools",
			"request": "attach",
			"url": "${workspaceFolder}/dist/game_debug.html",
			// "url": "c:\\Users\\boazp\\.vscode\\extensions\\ms-edgedevtools.vscode-edge-devtools-2.1.1\\out\\startpage\\index.html",
			"presentation": {
				"hidden": true
			}
		}
	],
	// "compounds": [
	// 	{
	// 		"name": "Launch Edge and attach DevTools",
	// 		"configurations": [
	// 			"Debug the game!",
	// 			"Open Edge DevTools"
	// 		]
	// 	}
	// ],
}