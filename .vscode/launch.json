{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "msedge",
			"version": "stable",
			"request": "launch",
			"name": "Debug the game!",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate",
				"--remote-debugging-port=9222"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 1
			}
		},
		{
			"type": "msedge",
			"version": "stable",
			"request": "launch",
			"name": "Debug the MSXSOUND!",
			"url": "${workspaceFolder}/src/bmsx/bla.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate",
				"--remote-debugging-port=9222"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 3
			}
		},
		{
			"type": "msedge",
			"version": "stable",
			"request": "launch",
			"name": "Run the game in non-debug mode!",
			"url": "${workspaceFolder}/dist/game.html",
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate"
			],
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"presentation": {
				"hidden": false,
				"group": "",
				"order": 2
			}
		},
		{
			"type": "vscode-edge-devtools.debug",
			"name": "Open Edge DevTools",
			"request": "attach",
			"url": "${workspaceFolder}/dist/game_debug.html",
			"presentation": {
				"hidden": true
			}
		},
		{
			"type": "msedge",
			"name": "a:/src/ASCII-art.html",
			"request": "launch",
			"url": "a:/src/ASCII-art.html",
			"showAsyncStacks": true,
			"smartStep": true,
			"disableNetworkCache": true,
			"runtimeArgs": [
				"--nolazy",
				"--allow-file-access-from-files",
				"--disable-session-crashed-bubble",
				"-inprivate"
			]
		},
		{
			"type": "msedge",
			"name": "http://127.0.0.1:3000/scripts/ascii_shader.html",
			"request": "launch",
			"url": "http://127.0.0.1:3000/scripts/ascii_shader.html"
		}
	],
