{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "chrome",
			"request": "launch",
			"name": "Debug the game!",
			// "url": "file:///${workspaceFolder}/game.html",
			"url": "http://127.0.0.1:8887/dist/game.html",
			"webRoot": "${workspaceFolder}",
			"sourceMapPathOverrides": {
				"../src/*": "${workspaceFolder}/src/*",
				"./bmsx/*": "${workspaceFolder}/BoazEngineJS/*",
			},
			"runtimeArgs": [
				// "--disable-web-security"
			],
			// "preLaunchTask": "pack (losse taak)",
			"sourceMaps": true,
			"showAsyncStacks": true,
			"smartStep": true,
			"pathMapping": {
				"http://127.0.0.1:80/": "${workspaceFolder}",
			}
		}
	]
}