{
    // "extends": "../tsconfig.json", // path to the main tsconfig.json file
    "compilerOptions": {
        "noEmit": true, // Optional - see note below
        "target": "esnext",
        // "rewriteRelativeImportExtensions": true,
        "erasableSyntaxOnly": true,
        "verbatimModuleSyntax": false,
        "composite": false,
        "declaration": false,
        "rootDir": "../",
        "module": "NodeNext",
        "moduleResolution": "nodenext"
    },
    "include": [
        "./**/*.ts",
        ".rompacker.rompack.d.ts",
        "../src/bmsx/binencoder.ts",
    ],
    "exclude": [
        "rom.ts",
    ]
}
